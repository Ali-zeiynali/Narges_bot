TELEGRAM_TOKEN=your-telegram-bot-token
GROQ_API_KEY=
NVIDIA_API_KEY=
NARAROUTER_API_KEY=

# Groq
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.7
GROQ_MAX_COMPLETION_TOKENS=7000
# Empty means reuse TELEGRAM_PROXY for Groq.
GROQ_PROXY=

# Multi-provider router. Requests are routed only through this ordered config.
# Missing env keys are skipped automatically.
AI_PROVIDERS_CONFIG=config/ai_providers.json
VISION_PROVIDERS_CONFIG=config/vision_providers.json
MEDIA_STORAGE_DIR=data/media
IMAGE_DAILY_LIMIT=10
MAX_IMAGE_FILE_BYTES=8388608
MAX_MEDIA_FILE_BYTES=33554432

# Validation
MAX_REQUEST_TOKENS=7000
MAX_API_INPUT_TOKENS=3600
MAX_MESSAGE_CHARS=1800

# Persona cache version. Change it when persona shards change.
PERSONA_VERSION=2026-07-05.1

# Database. Production should use DATABASE_URL, for example Supabase Postgres.
# URL-encode special characters in the password.
# DATABASE_URL=postgresql://postgres.xxxxx:YOUR_URL_ENCODED_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Local fallback for debugging when DATABASE_URL is empty.
DATABASE_PATH=data/narges.sqlite3

# Admins and support
ADMIN_IDS=
SUPPORT_URL=https://t.me/your_support
ADMIN_PANEL_TOKEN=change-this-admin-password

# Required-channel checks are stored in the admin panel/SQLite and start empty.
MEMBERSHIP_CACHE_SECONDS=60
ADMIN_BYPASS_MINUTES=60

# Free-plan limits
FREE_DAILY_QUOTA=40
FREE_MONTHLY_QUOTA=300
RATE_LIMIT_SHORT_COUNT=6
RATE_LIMIT_SHORT_WINDOW_SECONDS=120
RATE_LIMIT_LONG_COUNT=15
RATE_LIMIT_LONG_WINDOW_SECONDS=600

# Debug tools. Keep off in production.
DEBUG_MODE=false
DEBUG_USER_IDS=

# Optional common name conversions. JSON object, lowercase keys.
NAME_TRANSLITERATION_MAP={"ali":"علی","mohammad":"محمد","reza":"رضا","sara":"سارا","zahra":"زهرا"}

# Telegram network. Leave empty if you do not need a proxy.
TELEGRAM_PROXY=

# Webhook mode for Render.
# Set this to your Render public URL, for example: https://narges-bot.onrender.com
# Render may also provide RENDER_EXTERNAL_URL automatically.
WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_SECRET=change-this-long-random-string
TELEGRAM_DROP_PENDING_UPDATES=false
WEBHOOK_QUEUE_MAXSIZE=500
WEBHOOK_WORKER_COUNT=4
WEBHOOK_RATE_LIMIT_COUNT=30
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_IDEMPOTENCY_MAX_ITEMS=10000
TELEGRAM_BACKLOG_LATEST_ONLY=true
TELEGRAM_BACKLOG_GRACE_SECONDS=30
TELEGRAM_BACKLOG_DEBOUNCE_SECONDS=2
WEBHOOK_WATCHDOG_SECONDS=300

# Logging. On Render with a persistent disk use:
# LOG_FILE=/var/data/logs/bot.log
LOG_FILE=logs/bot.log
LOG_LEVEL=INFO

# Re-engagement message after user inactivity.
REENGAGEMENT_ENABLED=true
REENGAGEMENT_AFTER_HOURS=30
REENGAGEMENT_MESSAGE=دلم برات تنگ شدهه🥺 کجایی
REENGAGEMENT_CHECK_SECONDS=600
