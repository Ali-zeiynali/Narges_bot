{
  "providers": [
    {
      "name": "nvidia",
      "enabled": true,
      "priority": 10,
      "type": "openai_compatible",
      "base_url": "https://integrate.api.nvidia.com/v1",
      "api_key_env": "NVIDIA_API_KEY",
      "models": ["nvidia/llama-3.3-nemotron-super-49b-v1.5"],
      "temperature": 0.7,
      "max_completion_tokens": 512,
      "timeout_seconds": 45,
      "supports_json_schema": false,
      "supports_prompt_cache": "unknown",
      "use_proxy": true,
      "health_check": true
    },
    {
      "name": "nararouter",
      "enabled": true,
      "priority": 20,
      "type": "openai_compatible",
      "base_url": "https://router.bynara.id/v1",
      "api_key_env": "NARAROUTER_API_KEY",
      "models": ["auto"],
      "temperature": 0.7,
      "max_completion_tokens": 512,
      "timeout_seconds": 45,
      "supports_json_schema": false,
      "supports_prompt_cache": "unknown",
      "use_proxy": true,
      "health_check": true,
      "experimental": true
    },
    {
      "name": "bazaarlink",
      "type": "openai_compatible",
      "enabled": false,
      "priority": 30,
      "base_url": "https://YOUR_BAZAARLINK_OPENAI_COMPATIBLE_BASE_URL/v1",
      "model": "YOUR_BAZAARLINK_MODEL",
      "api_keys": ["env:BAZAARLINK_API_KEY_1", "env:BAZAARLINK_API_KEY_2"],
      "temperature": 0.7,
      "max_completion_tokens": 512,
      "timeout_seconds": 45,
      "response_format": "none",
      "use_proxy": true,
      "health_check": true,
      "experimental": true,
      "prompt_cache": false
    },
    {
      "name": "mistral",
      "type": "openai_compatible",
      "enabled": true,
      "base_url": "https://api.mistral.ai/v1",
      "model": "mistral-small-latest",
      "api_keys": ["env:MISTRAL_API_KEY_1", "env:MISTRAL_API_KEY_2"],
      "temperature": 0.7,
      "max_completion_tokens": 512,
      "timeout_seconds": 45,
      "prompt_cache": false
    },
    {
      "name": "gemini",
      "type": "gemini_interactions",
      "enabled": true,
      "base_url": "https://generativelanguage.googleapis.com/v1beta/interactions",
      "model": "gemini-3.5-flash",
      "api_keys": ["env:GEMINI_API_KEY_1", "env:GEMINI_API_KEY_2"],
      "temperature": 0.7,
      "max_completion_tokens": 512,
      "timeout_seconds": 45,
      "prompt_cache": false
    },
    {
      "name": "openrouter",
      "type": "openai_compatible",
      "enabled": true,
      "base_url": "https://openrouter.ai/api/v1",
      "model": "google/gemini-flash-1.5",
      "api_keys": ["env:OPENROUTER_API_KEY_1", "env:OPENROUTER_API_KEY_2"],
      "temperature": 0.7,
      "max_completion_tokens": 512,
      "timeout_seconds": 45,
      "prompt_cache": false,
      "extra_headers": {
        "HTTP-Referer": "https://localhost/narges",
        "X-Title": "Narges"
      }
    },
    {
      "name": "cerebras",
      "type": "openai_compatible",
      "enabled": true,
      "base_url": "https://api.cerebras.ai/v1",
      "model": "llama-3.3-70b",
      "api_keys": ["env:CEREBRAS_API_KEY_1", "env:CEREBRAS_API_KEY_2"],
      "temperature": 0.7,
      "max_completion_tokens": 512,
      "timeout_seconds": 45,
      "prompt_cache": false
    },
    {
      "name": "groq",
      "type": "openai_compatible",
